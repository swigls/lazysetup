layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="file:~/.lazysetup/xdg_base/.config/zellij/plugins/zellij-attention.wasm" {
                enabled "true"
                waiting_icon "⏳"
                completed_icon "✅"
            }
        }
        children
    }
}
